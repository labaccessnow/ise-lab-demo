# Copy to .env and fill in your Proxmox host/node. The committed code/docs use ${PVE_HOST}/${PVE_NODE} placeholders.
PVE_HOST=pve.lab.example
PVE_NODE=pve
PVE_POOL=iselab
WLC_HOST=wlc.lab.example

# Cal.com -> backend webhook signature secret (Tier-2). Fail-closed when unset.
CAL_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET

# Authentik (the lab's own SSO) — the Tier-2 reconciler keeps the lab-active
# group equal to "bookings running right now" (desktop gate). API token lives in
# the SOPS store under authentik.api_token, not here.
AUTHENTIK_URL=http://0.0.0.0:9000
AUTHENTIK_LAB_ACTIVE_GROUP=REPLACE_WITH_GROUP_UUID

# Booking BFF (Tier-2): the backend books Cal.com server-side with the attendee
# email locked to the verified identity. Internal Cal.com address (bypasses the
# public forward-auth gate). REST API v1 is not deployed; we use /api/book/event.
CALCOM_INTERNAL_URL=http://0.0.0.0:3000
CALCOM_LAB_EVENT_ID=2
CALCOM_LAB_EVENT_SLUG=self-service-lab
CALCOM_LAB_EVENT_USER=labaccessnow
CALCOM_LAB_TZ=America/New_York

# Portal (Tier-1) overrides — defaults shown; only set to change them.
#ADMIN_GROUP=lab-admins
#BOOKING_EXEMPT_GROUPS=lab-admins,lab-approved

# Reservation tiers. Members of a PRIVILEGED group get the longer session + daily
# quota; everyone else (free demo) gets the FREE limits. To launch paid, just add
# users to the lab-paid group (already listed here). Minutes.
#BOOKING_PRIVILEGED_GROUPS=lab-admins,lab-paid
#BOOKING_PRIV_SESSION_MIN=480   # 8h per session
#BOOKING_PRIV_DAILY_MIN=480     # 8h per day
#BOOKING_FREE_SESSION_MIN=60    # 1h per session
#BOOKING_FREE_DAILY_MIN=60      # 1h per day
