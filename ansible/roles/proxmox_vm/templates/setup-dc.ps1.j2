# Phase 1 (first auto-logon): NIC, guest agent, then promote the forest.
# Vars: ip, enclave_netmask(->prefix), enclave_gateway, ad_domain, ad_netbios, win_dsrm_password
Start-Transcript -Path C:\Windows\Temp\setup-dc.log -Force

$nic = Get-NetAdapter -Physical | Where-Object Status -eq 'Up' | Select-Object -First 1
if (-not $nic) { $nic = Get-NetAdapter -Physical | Select-Object -First 1 }
Remove-NetIPAddress -InterfaceIndex $nic.ifIndex -AddressFamily IPv4 -Confirm:$false -ErrorAction SilentlyContinue
New-NetIPAddress -InterfaceIndex $nic.ifIndex -IPAddress {{ ip }} -PrefixLength 24 -DefaultGateway {{ enclave_gateway }} -ErrorAction SilentlyContinue
Set-DnsClientServerAddress -InterfaceIndex $nic.ifIndex -ServerAddresses 127.0.0.1

# QEMU guest agent (best-effort; needs the virtio-serial driver to actually talk to the host)
foreach ($v in (Get-Volume | Where-Object DriveLetter)) {
  $m = ($v.DriveLetter + ':\guest-agent\qemu-ga-x86_64.msi')
  if (Test-Path $m) { Start-Process msiexec.exe -ArgumentList "/i `"$m`" /qn /norestart" -Wait; break }
}

Set-ItemProperty 'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\RunOnce' -Name DCPhase2 `
  -Value 'powershell -ExecutionPolicy Bypass -NoProfile -File C:\Windows\Temp\phase2.ps1' -ErrorAction SilentlyContinue

Install-WindowsFeature -Name AD-Domain-Services -IncludeManagementTools
Import-Module ADDSDeployment
$dsrm = ConvertTo-SecureString '{{ win_dsrm_password }}' -AsPlainText -Force
Install-ADDSForest -DomainName '{{ ad_domain }}' -DomainNetbiosName '{{ ad_netbios }}' `
  -SafeModeAdministratorPassword $dsrm -InstallDns:$true `
  -ForestMode WinThreshold -DomainMode WinThreshold -NoRebootOnCompletion:$false -Force:$true
Stop-Transcript
